<!--
  Wazuh Custom Detection Rules: Payment Security
  Author: Evgeniy Gantman
  Version: 1.0.0
  Last Updated: 2026-05-04

  Purpose:
    Detect payment-related security events including PAN data exposure in logs,
    transaction anomalies, failed payment spikes, and card testing attacks.
    Designed for PCI DSS CDE environments with high-fidelity, low-noise tuning.

  Compliance:
    - PCI DSS v4.0 Requirement 10.2 — Log all security events in the CDE
    - PCI DSS v4.0 Requirement 10.7 — Detect and respond to failures of critical controls
    - NIST SP 800-92 — Guide to Computer Security Log Management
    - NIST CSF DE.CM-3 — Personnel activity is monitored to detect potential events

  MITRE ATT&amp;CK Techniques Covered:
    - T1530 — Data from Cloud Storage (PAN in object storage logs)
    - T1005 — Data from Local System (PAN written to disk logs)
    - T1078 — Valid Accounts (credential stuffing for payment portals)
    - T1485 — Data Destruction (bulk transaction deletions)
    - T1110.003 — Password Spraying (card-not-present fraud attempts)

  Rule ID Range: 100000–100099 (Payment Security)

  Deployment:
    Place in /var/ossec/etc/rules/payment-rules.xml
    Restart: systemctl restart wazuh-manager

  Tuning Notes:
    - Adjust frequency thresholds based on baseline transaction volumes
    - Whitelist known payment processor IPs in local rules
    - PAN regex designed to minimize false positives (Luhn-valid patterns)
-->

<group name="payment,pci-dss,custom">

  <!-- =========================================================
       Rule Group: PAN / Sensitive Data Exposure in Logs
       Detection: PAN numbers written to log files or stdout
       MITRE: T1005 (Data from Local System), T1530 (Cloud Storage Data)
       Severity: CRITICAL — PAN in cleartext violates PCI DSS 3.4
       ========================================================= -->

  <!-- Base rule: Match common log formats that contain 16-digit sequences
       Uses regex matching Luhn-valid card number patterns:
         - 4xxx xxxx xxxx xxxx (Visa)
         - 5[1-5]xx xxxx xxxx xxxx (Mastercard)
         - 3[47]xx xxxxxx xxxxx (AmEx 15-digit)
         - 6011 xxxx xxxx xxxx (Discover)
       Regex also matches space/dash/no-separator formats.
  -->
  <rule id="100000" level="15">
    <decoded_as>json</decoded_as>
    <regex type="pcre2">
      (?:4[0-9]{12}(?:[0-9]{3})?|
         5[1-5][0-9]{14}|
         3[47][0-9]{13}|
         3(?:0[0-5]|[68][0-9])[0-9]{11}|
         6(?:011|5[0-9]{2})[0-9]{12}|
         (?:2131|1800|35\d{3})\d{11})
    </regex>
    <description>PAN (Primary Account Number) detected in log output - PCI DSS violation</description>
    <mitre>
      <id>T1005</id>
      <id>T1530</id>
    </mitre>
    <group>pci_dss_3.4,pci_dss_10.2.1,gdpr_II_5.1.f,hipaa_164.312.a.2.iv,nist_800_53_AU.9</group>
    <!-- Tag for immediate SOC escalation -->
    <options>alert_by_email</options>
  </rule>

  <!-- Escalate if PAN detected in payment service specifically -->
  <rule id="100001" level="15">
    <if_sid>100000</if_sid>
    <field name="service">payment|checkout|billing|card-processor</field>
    <description>PAN exposed in payment service logs — immediate PCI DSS incident required</description>
    <mitre>
      <id>T1005</id>
    </mitre>
    <group>pci_dss_3.4,pci_dss_3.3,pci_dss_10.2.1</group>
    <options>alert_by_email,no_counter</options>
  </rule>

  <!-- Detect truncated PAN masking bypass: first 6 and last 4 displayed (BIN + last4)
       This pattern detects when applications print more than allowed digits -->
  <rule id="100002" level="12">
    <decoded_as>json</decoded_as>
    <regex type="pcre2">
      (?:card|pan|cc|credit_card|card_number)\s*[:=]\s*
      [0-9]{6,}[0-9xX*\-\s]{2,}[0-9]{4}
    </regex>
    <description>Potential partial PAN exposure in logs — verify masking policy compliance</description>
    <mitre>
      <id>T1005</id>
    </mitre>
    <group>pci_dss_3.4,pci_dss_10.2.1</group>
  </rule>

  <!-- CVV/CVC data detected in logs — NEVER allowed per PCI DSS 3.2 -->
  <rule id="100003" level="15">
    <decoded_as>json</decoded_as>
    <regex type="pcre2">
      (?:cvv|cvc|csc|cvv2|cvc2)\s*[:=]\s*[0-9]{3,4}\b
    </regex>
    <description>CVV/CVC security code detected in logs — critical PCI DSS violation, prohibited storage</description>
    <mitre>
      <id>T1005</id>
    </mitre>
    <group>pci_dss_3.2,pci_dss_10.2.1</group>
    <options>alert_by_email</options>
  </rule>

  <!-- Track1/Track2 magnetic stripe data in logs -->
  <rule id="100004" level="15">
    <decoded_as>json</decoded_as>
    <regex type="pcre2">
      (?:track[12]|magnetic_stripe|magstripe)\s*[:=]\s*
      [%B][0-9]{13,19}\^[A-Z\s\/]{2,26}\^[0-9]{7}
    </regex>
    <description>Magnetic stripe Track data detected in logs — critical PCI DSS violation</description>
    <mitre>
      <id>T1005</id>
    </mitre>
    <group>pci_dss_3.2,pci_dss_10.2.1</group>
    <options>alert_by_email</options>
  </rule>


  <!-- =========================================================
       Rule Group: Transaction Anomalies
       Detection: Unusual transaction patterns suggesting fraud or attack
       MITRE: T1110.003 (Password Spray), T1499 (Endpoint DoS)
       ========================================================= -->

  <!-- High-velocity transaction from single IP — card testing pattern
       Thresholds: >50 transactions in 60 seconds from same source_ip
       Card testers use bots to validate stolen cards with small amounts -->
  <rule id="100010" level="13" frequency="50" timeframe="60">
    <decoded_as>json</decoded_as>
    <field name="event_type">transaction_attempt|payment_request|charge_attempt</field>
    <same_field>source_ip</same_field>
    <description>High-velocity payment attempts from single IP — card testing attack suspected</description>
    <mitre>
      <id>T1110.003</id>
      <id>T1499.002</id>
    </mitre>
    <group>pci_dss_6.4.1,pci_dss_10.2.1,gdpr_II_5.1.f</group>
  </rule>

  <!-- Rapid small-amount transactions — card validity testing
       Attackers test stolen cards with $0.01-$1.00 charges to verify validity
       before using cards for larger fraudulent purchases -->
  <rule id="100011" level="12" frequency="20" timeframe="120">
    <decoded_as>json</decoded_as>
    <field name="event_type">transaction_attempt|payment_request</field>
    <field name="amount" type="pcre2">^0\.[0-9]{2}$|^[01]\.[0-9]{2}$</field>
    <same_field>source_ip</same_field>
    <description>Multiple micro-transactions from single source — card testing with small amounts detected</description>
    <mitre>
      <id>T1110.003</id>
    </mitre>
    <group>pci_dss_6.4.1,pci_dss_10.2.1</group>
  </rule>

  <!-- Unusual large transaction outside business hours
       Detects transactions over $10,000 between midnight and 6am (UTC)
       Adjust threshold to match your organization's risk tolerance -->
  <rule id="100012" level="10">
    <decoded_as>json</decoded_as>
    <field name="event_type">transaction_success|payment_completed</field>
    <field name="amount" type="pcre2">^[0-9]{5,}</field>
    <time>00:00:00-06:00:00</time>
    <description>High-value transaction ($10,000+) processed outside business hours — review required</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>pci_dss_10.2.1,pci_dss_10.3</group>
  </rule>

  <!-- Bulk payment record deletion — potential data destruction or anti-forensics -->
  <rule id="100013" level="14" frequency="10" timeframe="300">
    <decoded_as>json</decoded_as>
    <field name="event_type">transaction_delete|payment_void|record_purge</field>
    <same_field>operator_id</same_field>
    <description>Bulk transaction deletion by single operator — potential data destruction or fraud cover-up</description>
    <mitre>
      <id>T1485</id>
      <id>T1070.004</id>
    </mitre>
    <group>pci_dss_10.2.1,pci_dss_10.3</group>
    <options>alert_by_email</options>
  </rule>

  <!-- Payment processor API key used from unexpected location
       Baseline: API keys should only be used from payment service subnet -->
  <rule id="100014" level="13">
    <decoded_as>json</decoded_as>
    <field name="event_type">api_key_auth|payment_api_request</field>
    <field name="source_ip" negate="yes" type="pcre2">
      ^(?:10\.100\.\d{1,3}\.\d{1,3}|192\.168\.50\.)
    </field>
    <description>Payment API key used from unexpected IP — possible key compromise or exfiltration</description>
    <mitre>
      <id>T1078.001</id>
      <id>T1552.001</id>
    </mitre>
    <group>pci_dss_8.2.1,pci_dss_10.2.1</group>
    <options>alert_by_email</options>
  </rule>


  <!-- =========================================================
       Rule Group: Failed Payment Spikes
       Detection: Sustained decline rates indicating attacks or outages
       MITRE: T1110 (Brute Force), T1499 (DoS)
       ========================================================= -->

  <!-- Payment failure spike — >30 failures in 60 seconds
       Normal decline rate is ~2-5% of transactions; spikes indicate:
       - Card testing attacks (stolen card validation)
       - Credential stuffing against payment portal
       - Service degradation requiring ops escalation -->
  <rule id="100020" level="11" frequency="30" timeframe="60">
    <decoded_as>json</decoded_as>
    <field name="event_type">payment_failed|transaction_declined|charge_error</field>
    <description>Payment failure spike detected — 30+ declines per minute, investigate for card testing or outage</description>
    <mitre>
      <id>T1110</id>
      <id>T1499</id>
    </mitre>
    <group>pci_dss_6.4.1,pci_dss_10.2.1</group>
  </rule>

  <!-- Sustained high failure rate from single BIN prefix
       BIN (Bank Identification Number) targeting: attacker uses single BIN
       for all attempts, suggesting organized card testing operation -->
  <rule id="100021" level="13" frequency="15" timeframe="120">
    <decoded_as>json</decoded_as>
    <field name="event_type">payment_failed|transaction_declined</field>
    <field name="decline_code">do_not_honor|insufficient_funds|invalid_card</field>
    <same_field>card_bin</same_field>
    <description>High failure rate on single BIN prefix — targeted card-not-present fraud campaign suspected</description>
    <mitre>
      <id>T1110.003</id>
    </mitre>
    <group>pci_dss_6.4.1,pci_dss_10.2.1</group>
  </rule>

  <!-- 3DS challenge bypass attempt — repeated step-up auth failures
       Attackers attempt to exhaust 3DS challenges hoping to fall back
       to non-3DS path on some issuer configurations -->
  <rule id="100022" level="12" frequency="5" timeframe="300">
    <decoded_as>json</decoded_as>
    <field name="event_type">3ds_challenge_failed|3ds_authentication_error</field>
    <same_field>session_id</same_field>
    <description>Repeated 3DS challenge failures on same session — possible 3DS bypass attempt</description>
    <mitre>
      <id>T1078</id>
      <id>T1110</id>
    </mitre>
    <group>pci_dss_8.2.1,pci_dss_6.4.1</group>
  </rule>

  <!-- Refund anomaly: refund without prior matching charge
       Money laundering pattern: inject refunds for non-existent transactions -->
  <rule id="100023" level="14">
    <decoded_as>json</decoded_as>
    <field name="event_type">refund_issued|credit_applied</field>
    <field name="original_transaction_id" type="pcre2">^(null|none|N\/A|)$</field>
    <description>Refund issued without matching original transaction ID — potential financial fraud</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>pci_dss_10.2.1,pci_dss_10.3</group>
    <options>alert_by_email</options>
  </rule>


  <!-- =========================================================
       Rule Group: Payment Service Integrity
       Detection: Configuration tampering and service anomalies
       MITRE: T1565 (Data Manipulation), T1070 (Indicator Removal)
       ========================================================= -->

  <!-- Payment routing configuration changed
       Any change to which PSP/acquirer handles transactions is high-risk -->
  <rule id="100030" level="14">
    <decoded_as>json</decoded_as>
    <field name="event_type">config_change|routing_update</field>
    <field name="component">payment_router|psp_config|acquirer_config</field>
    <description>Payment routing configuration modified — verify authorized change with change management</description>
    <mitre>
      <id>T1565.001</id>
    </mitre>
    <group>pci_dss_6.5.1,pci_dss_10.2.1,pci_dss_12.3</group>
    <options>alert_by_email</options>
  </rule>

  <!-- Payment encryption key rotation skipped or overdue
       PCI DSS 3.6 requires cryptoperiod management for payment keys -->
  <rule id="100031" level="13">
    <decoded_as>json</decoded_as>
    <field name="event_type">key_expiry_warning|encryption_key_overdue</field>
    <field name="key_type">payment_encryption|dek|kek|pin_key</field>
    <description>Payment encryption key expiry warning — cryptoperiod management required per PCI DSS 3.6</description>
    <mitre>
      <id>T1600</id>
    </mitre>
    <group>pci_dss_3.6,pci_dss_3.7</group>
  </rule>

  <!-- Payment audit log tampering detected
       Any deletion or modification of payment audit records is a critical finding -->
  <rule id="100032" level="15">
    <decoded_as>json</decoded_as>
    <field name="event_type">audit_log_delete|audit_record_modify|log_truncate</field>
    <field name="log_source">payment|transaction|pci|audit</field>
    <description>Payment audit log tampering detected — critical PCI DSS incident, possible evidence destruction</description>
    <mitre>
      <id>T1070.002</id>
    </mitre>
    <group>pci_dss_10.2.1,pci_dss_10.3.2,pci_dss_10.5</group>
    <options>alert_by_email</options>
  </rule>

</group>
